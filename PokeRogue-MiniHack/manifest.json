{
  "manifest_version": 3,
  "name": "PokeRogue Mini-Hack Extension",
  "version": "1.0.2",
  "description": "PokeRogue 100% Shiny & Egg Hacker (Unified UID Update)",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": [
    "https://pokerogue.net/*",
    "https://beta.pokerogue.net/*",
    "https://mokerogue.net/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon.png",
      "32": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  },
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://pokerogue.net/*",
        "https://beta.pokerogue.net/*",
        "https://mokerogue.net/*"
      ],
      "js": ["injector.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["mod.min.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
