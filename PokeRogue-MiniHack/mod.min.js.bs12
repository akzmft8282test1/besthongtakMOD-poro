  function isFeatureAllowed(featureName) {
    if (!activeLicense || !activeLicense.valid) return false;
    if (Date.now() > activeLicense.expiresAt) {
      activeLicense = null;
      alert(
        "⏰ 쿠폰 이용 가능 제한 시간이 만료되었습니다. 패널 가동을 중지합니다.",
      );
      document.getElementById("hack-features-list").style.display = "none";
      document.getElementById("auth-panel").style.display = "block";
      if (eggPityInterval) {
        clearInterval(eggPityInterval);
        eggPityInterval = null;
      }
      return false;
    }
    return activeLicense.features.includes(featureName);
  }

  async function registerLicenseToken(couponCode) {
    try {
      const res = await fetch(`${SERVER_URL}/api/license/redeem`, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ couponCode }),
      });
      const data = await res.json();
      if (data.valid) {
        activeLicense = {
          valid: true,
          features: data.features,
          expiresAt: Date.now() + data.durationMinutes * 60 * 1000,
        };
        alert(
          `🎉 일회성 쿠폰 등록 성공!\n유효 시간: ${data.durationMinutes}분\n활성화 기능: [${data.features.join(", ")}]`,
        );
        document.getElementById("auth-panel").style.display = "none";
        document.getElementById("hack-features-list").style.display = "block";
        return true;
      } else {
        alert(`❌ 쿠폰 인증 실패: ${data.message}`);
        return false;
      }
    } catch (e) {
      alert("서버와 통신 중 네트워크 오류가 발생했습니다.");
      return false;
    }
  }

  function getBattleScene() {
    try {
      if (
        window.Phaser &&
        window.Phaser.Display.Canvas.CanvasPool.pool.length > 0
      ) {
        return window.Phaser.Display.Canvas.CanvasPool.pool[0].parent.game.scene
          .keys.battle;
      }
    } catch (e) {}
    return null;
  }

  function getCurrentShopScene() {
    try {
      if (
        window.Phaser &&
        window.Phaser.Display.Canvas.CanvasPool.pool.length > 0
      ) {
        return window.Phaser.Display.Canvas.CanvasPool.pool[0].parent.game.scene
          .scenes[
          window.Phaser.Display.Canvas.CanvasPool.pool[0].parent.game.scene
            .scenes.length - 1
        ];
      }
    } catch (e) {}
    return null;
  }

  // 새 코드로 추가된 안전한 유틸 전용 래퍼 함수들
  function updateEggListDisplay() {
    const scene = getBattleScene();
    if (!scene || !scene.ui) return;
    const handler = scene.ui.getHandler();
    if (
      window.PokeRogue &&
      window.PokeRogue.ui &&
      handler instanceof window.PokeRogue.ui.EggListUiHandler
    ) {
      const cursor = handler.getCursor();
      handler.setEggDetails(scene.gameData?.eggs[cursor]);
      handler.eggListIconContainer.removeAll(true);
      handler.show([]);
      handler.setCursor(cursor);
      handler.iconAnimHandler.addOrUpdate(
        handler.eggListIconContainer.getAt(cursor),
        2,
      );
    }
  }

  // ==========================================
  // [신규 주입 코어] 런타임 제어 비즈니스 로직
  // ==========================================

  // [방식 1] Vouchers 직접 입력 조작
  function injectCustomVouchers() {
    if (!isFeatureAllowed("money")) return alert("🚫 사용 권한이 부족합니다.");
    const battleScene = getBattleScene();
    if (!battleScene || !battleScene.gameData)
      return alert("게임 화면에서 진행해주세요.");

    const count = parseInt(document.getElementById("input-voucher-val").value);
    if (isNaN(count)) return alert("올바른 수치를 입력하세요.");

    try {
      battleScene.gameData.vouchers = count;
      if (typeof battleScene.gameData.saveSystem === "function")
        battleScene.gameData.saveSystem();
      alert(`🎫 Voucher 데이터가 성공적으로 변경되었습니다: [${count}]`);
    } catch (e) {
      alert("보안 세션 변경 실패");
    }
  }

  // [방식 2] 모든 바우처 종류 갯수 개별 정밀 주입 수정 (새로 발견된 방식)
  function injectDetailedVouchers() {
    if (!isFeatureAllowed("money")) return alert("🚫 사용 권한이 부족합니다.");
    const battleScene = getBattleScene();
    if (
      !battleScene ||
      !battleScene.gameData ||
      !battleScene.gameData.voucherCounts
    )
      return alert("뽑기방 진입 또는 로드 후 시도하세요.");

    const count =
      parseInt(document.getElementById("input-voucher-val").value) || 0;
    try {
      for (let i = 0; i < 4; i++) {
        battleScene.gameData.voucherCounts[i] = count;
      }
      const handler = battleScene.ui.getHandler();
      if (handler && typeof handler.updateVoucherCounts === "function") {
        handler.updateVoucherCounts();
      }
      alert(
        `🎫 [방식 2] 모든 등급의 Voucher 수량이 [${count}]개로 동기화되었습니다.`,
      );
    } catch (e) {
      alert("정밀 바우처 변조 오류");
    }
  }

  // Egg Pity 실시간 1초 무한 유지 루프 변조기
  function toggleEggPityEngine() {
    if (!isFeatureAllowed("egg")) return alert("🚫 사용 권한이 부족합니다.");
    const btn = document.getElementById("btn-toggle-pity");

    if (eggPityInterval) {
      clearInterval(eggPityInterval);
      eggPityInterval = null;
      btn.innerText = "상태: OFF (인터벌 정지)";
      btn.style.background = "#555";
      return;
    }

    const pityVal = parseInt(document.getElementById("input-egg-pity").value);
    if (isNaN(pityVal)) return alert("올바른 Pity 값을 정수값으로 입력하세요.");

    eggPityInterval = setInterval(() => {
      const battleScene = getBattleScene();
      if (!battleScene || !battleScene.gameData) return;

      try {
        if (battleScene.gameData.eggPity) {
          for (let i = 0; i < battleScene.gameData.eggPity.length; i++) {
            battleScene.gameData.eggPity[i] = pityVal;
          }
        }
      } catch (e) {}
    }, 100);

    btn.innerText = "상태: ON (0.1초마다 동기화 중)";
    btn.style.background = "#2ea44f";
    alert(`🥚 Egg Pity 고정 스케줄러가 활성화되었습니다: [${pityVal}]`);
  }

  // Unlock Pity 및 전 도감/숨특/알기술 완벽 오버라이드
  function injectUnlockPityAndDex() {
    if (!isFeatureAllowed("starters"))
      return alert("🚫 사용 권한이 부족합니다.");
    const battleScene = getBattleScene();
    if (!battleScene || !battleScene.gameData)
      return alert("게임이 로드된 후 진행해주세요.");

    const pityVal =
      parseInt(document.getElementById("input-unlock-pity").value) || 0;

    try {
      const { dexData, starterData } = battleScene.gameData;
      if (dexData) {
        Object.keys(dexData).forEach((key) => {
          const data = dexData[key];
          data.seenAttr = BigInt(Number.MAX_SAFE_INTEGER);
          data.caughtAttr = BigInt(Number.MAX_SAFE_INTEGER);
          data.natureAttr = 33554431;
          data.seenCount = 999;
          data.caughtCount = 999;
          data.hatchedCount = 999;
          data.ivs = [31, 31, 31, 31, 31, 31];
          if (data.variants) data.variants = [true, true, true];
        });
      }
      if (starterData) {
        Object.keys(starterData).forEach((key) => {
          const data = starterData[key];
          data.candyCount = 999;
          data.friendship = 255;
          data.abilityAttr = 7;
          data.passiveAttr = NO_PASSIVE_IDS.has(key) ? 0 : 3;
          data.valueReduction = 99;
          data.classicWinCount = 10;
          data.eggMovesStatus = 15;
          data.pity = pityVal;
        });
      }
      if (typeof battleScene.gameData.saveSystem === "function")
        battleScene.gameData.saveSystem();
      alert(
        `🧬 올 도감 완전 해금 및 스타터 Pity 수치가 [${pityVal}]로 저장되었습니다.`,
      );
    } catch (e) {
      alert("도감 변조 실패");
    }
  }

  // 전체 업적(Achievements) 100% 원클릭 완벽 해금
  function injectAllAchievementsComplete() {
    if (!isFeatureAllowed("starters"))
      return alert("🚫 사용 권한이 부족합니다.");
    const battleScene = getBattleScene();
    if (!battleScene || !battleScene.gameData)
      return alert("게임에 접속한 뒤 클릭해주세요.");

    try {
      const timestamp = Date.now();
      if (!battleScene.gameData.achvUnlocks) {
        battleScene.gameData.achvUnlocks = {};
      }
      for (let i = 1; i <= 200; i++) {
        battleScene.gameData.achvUnlocks[i.toString()] = timestamp;
      }

      if (typeof battleScene.gameData.saveSystem === "function")
        battleScene.gameData.saveSystem();
      alert(
        "🏆 클래식 승리 및 단일 타입 챌린지 포함 모든 게임 업적이 전면 해금되었습니다.",
      );
    } catch (e) {
      alert("업적 모듈 인젝션 중 에러 발생");
    }
  }

  // [이로치 조작 방식 1] 기존 모디파이어 스택 기반
  async function setMaxShinyRate() {
    if (!isFeatureAllowed("shiny")) return alert("🚫 권한 없음");
    const battleScene = getBattleScene();
    if (!battleScene) return;
    const modifiers = battleScene.modifiers;
    let index = modifiers.findIndex(
      ({ type: { localeKey } }) =>
        localeKey === "modifierType:ModifierType.SHINY_CHARM",
    );
    if (index === -1) {
      try {
        const shinyCharmModifier =
          new window.PokeRogue.modifier.ShinyRateBoosterModifier(
            window.PokeRogue.modifier.modifierTypes.SHINY_CHARM(),
          );
        await battleScene.updateModifiers(true, true);
        await battleScene.addModifier(
          shinyCharmModifier,
          false,
          false,
          false,
          true,
        );
        index = modifiers.findIndex(
          ({ type: { localeKey } }) =>
            localeKey === "modifierType:ModifierType.SHINY_CHARM",
        );
      } catch (err) {
        return;
      }
    }
    if (index !== -1) {
      modifiers[index].stackCount = 200000;
      await battleScene.updateModifiers(true, true);
      alert("✨ [방식 1] 이로치 부스터 스택 조작 완료!");
    }
  }

  // [이로치 조작 방식 2] 새 코드 기반: 페이즈 우회 후킹 강제 지정 방식
  function activateWildShiny100p() {
    if (!isFeatureAllowed("shiny")) return alert("🚫 권한 없음");
    hackDataStore.WildShiny100p = !hackDataStore.WildShiny100p;
    const btn = document.getElementById("btn-toggle-shiny-v2");
    if (hackDataStore.WildShiny100p) {
      btn.innerText = "방식 2: ON (야생 100% 강제 후킹)";
      btn.style.background = "#2ea44f";
      // 런타임 페이즈 강제 바인딩 인젝션
      try {
        const battleScene = getBattleScene();
        if (battleScene && window.PokeRogue) {
          // 스택 삽입
          var maxStackCount = 20;
          var modifiers = battleScene.modifiers;
          var index = modifiers.findIndex(
            (o) => o.type.localeKey === "modifierType:ModifierType.SHINY_CHARM",
          );
          if (index === -1) {
            const mod = new window.PokeRogue.modifier.ShinyRateBoosterModifier(
              window.PokeRogue.modifier.modifierTypes.SHINY_CHARM(),
            );
            battleScene.addModifier(mod, false, false, false, true);
          }
        }
      } catch (e) {}
      alert(
        "✨ [방식 2] 야생 포켓몬 100% 이로치 후킹 엔드포인트가 연동되었습니다.",
      );
    } else {
      btn.innerText = "방식 2: OFF (야생 100% 해제)";
      btn.style.background = "#555";
    }
  }

  // [새 코드 연동] 상점 100% 무료 리롤 활성화 스위치
  function toggleFreeRerolls() {
    if (!isFeatureAllowed("money")) return alert("🚫 권한 없음");
    hackDataStore.FreeRerolls = !hackDataStore.FreeRerolls;
    const btn = document.getElementById("btn-toggle-free-reroll");
    btn.innerText = hackDataStore.FreeRerolls
      ? "무료 리롤: ACTIVE"
      : "무료 리롤: INACTIVE";
    btn.style.background = hackDataStore.FreeRerolls ? "#2ea44f" : "#555";
  }

