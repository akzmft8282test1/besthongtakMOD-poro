  // [새 코드 연동] 알 인벤토리 강제 즉시 부화 세팅 (0 Waves)
  function setAllEggsHatchZero() {
    if (!isFeatureAllowed("egg")) return alert("🚫 권한 없음");
    const battleScene = getBattleScene();
    if (!battleScene || !battleScene.gameData || !battleScene.gameData.eggs)
      return alert("게임 데이터 로드 실패");

    try {
      battleScene.gameData.eggs.forEach((egg) => {
        egg._hatchWaves = 0;
      });
      updateEggListDisplay();
      alert(
        "🥚 현재 보유 중인 모든 알의 잔여 부화 걸음수가 0웨이브로 단축되었습니다!",
      );
    } catch (e) {
      alert("알 데이터 오버라이드 실패");
    }
  }

  // 기존의 맥스 스택 추가 기능 유지
  async function setMaxMULTI_LENSRate() {
    if (!isFeatureAllowed("shiny")) return;
    const battleScene = getBattleScene();
    if (!battleScene) return;
    const modifiers = battleScene.modifiers;
    let index = modifiers.findIndex(
      ({ type: { localeKey } }) =>
        localeKey === "modifierType:ModifierType.MULTI_LENS",
    );
    if (index === -1) {
      try {
        const mod = new window.PokeRogue.modifier.ShinyRateBoosterModifier(
          window.Phaser
            ? window.PokeRogue.modifier.modifierTypes.MULTI_LENS()
            : null,
        );
        await battleScene.updateModifiers(true, true);
        await battleScene.addModifier(mod, false, false, false, true);
        index = modifiers.findIndex(
          ({ type: { localeKey } }) =>
            localeKey === "modifierType:ModifierType.MULTI_LENS",
        );
      } catch (e) {}
    }
    if (index !== -1) {
      modifiers[index].stackCount = 200000;
      await battleScene.updateModifiers(true, true);
      alert("✨ 연타 확률 조작 성공!");
    }
  }

  async function setMaxCANDY_JARRate() {
    if (!isFeatureAllowed("shiny")) return;
    const battleScene = getBattleScene();
    if (!battleScene) return;
    const modifiers = battleScene.modifiers;
    let index = modifiers.findIndex(
      ({ type: { localeKey } }) =>
        localeKey === "modifierType:ModifierType.CANDY_JAR",
    );
    if (index === -1) {
      try {
        const mod = new window.PokeRogue.modifier.ShinyRateBoosterModifier(
          window.PokeRogue.modifier.modifierTypes.CANDY_JAR(),
        );
        await battleScene.updateModifiers(true, true);
        await battleScene.addModifier(mod, false, false, false, true);
        index = modifiers.findIndex(
          ({ type: { localeKey } }) =>
            localeKey === "modifierType:ModifierType.CANDY_JAR",
        );
      } catch (e) {}
    }
    if (index !== -1) {
      modifiers[index].stackCount = 200;
      await battleScene.updateModifiers(true, true);
      alert("✨ 사탕항아리 맥스 스택 조작 성공!");
    }
  }

