    const divBossSeg = document.createElement("div");
    divBossSeg.id = "boss-segment-row";
    divBossSeg.style.display = "none";
    divBossSeg.style.paddingLeft = "10px";
    const btnBossSeg = createButton(
      "└ 보스 체력 실드 세그먼트 무시: OFF",
      toggleIgnoreBoss,
      "#555",
      "white",
    );
    btnBossSeg.id = "btn-toggle-boss-seg";
    divBossSeg.appendChild(btnBossSeg);
    battleArr.push(divBossSeg);

    const btnCatch = createButton(
      "야생 포켓몬 무조건 포획: OFF",
      toggleAlwaysCatch,
      "#555",
      "white",
    );
    btnCatch.id = "btn-toggle-catch";
    battleArr.push(btnCatch);

    const divCatchEnd = document.createElement("div");
    divCatchEnd.id = "catch-end-row";
    divCatchEnd.style.display = "none";
    divCatchEnd.style.paddingLeft = "10px";
    const btnCatchEnd = createButton(
      "└ 무한다이노 등 최종전 포획 해제: OFF",
      toggleCatchInEnd,
      "#555",
      "white",
    );
    btnCatchEnd.id = "btn-toggle-catch-end";
    divCatchEnd.appendChild(btnCatchEnd);
    battleArr.push(divCatchEnd);

    addCategory("전투 편의성 및 원히트 킬 제어", battleArr);

    // --- 카테고리 [4] 상점 및 챌린지 인젝션 ---
    const shopArr = [];
    const btnFreeReroll = createButton(
      "상점 리롤 100% 무료화: OFF",
      toggleFreeRerolls,
      "#555",
      "white",
    );
    btnFreeReroll.id = "btn-toggle-free-reroll";
    shopArr.push(btnFreeReroll);

    shopArr.push(
      createButton(
        "🍀 팀 고유 행운(Luck) 99 강제 한도 초과",
        maxTeamLuckCheat,
        "#4682b4",
        "white",
      ),
    );
    shopArr.push(
      createButton(
        "🔴 상점 보상 테이블: 로그(로그) 고정 리롤",
        () => forceShopReroll(3),
        "#b22222",
        "white",
      ),
    );
    shopArr.push(
      createButton(
        "🟣 상점 보상 테이블: 마스터 등급 고정 리롤",
        () => forceShopReroll(4),
        "#9370db",
        "white",
      ),
    );

    addCategory("소지금 자금 및 상점 리롤 보정", shopArr);

    // --- 카테고리 [5] 도감 마스터 및 업적 완전 해금 ---
    const masterArr = [];
    masterArr.push(
      createButton(
        "🌟 전 스타터 해금 & 숨특 알기술 마스터",
        injectUnlockPityAndDex,
        "#ff4500",
        "white",
      ),
    );

    const btnInfPoints = createButton(
      "무한 스타터 선택 코스트 포인트: OFF",
      toggleInfSelectionPoints,
      "#555",
      "white",
    );
    btnInfPoints.id = "btn-toggle-inf-points";
    masterArr.push(btnInfPoints);

    masterArr.push(
      createButton(
        "🏆 클래식/챌린지 전체 세이브 업적 즉시 완료",
        injectAllAchievementsComplete,
        "#4b0082",
        "white",
      ),
    );
    masterArr.push(
      createButton(
        "⚔️ 적 버프 스트립 해제 및 소지템 박탈",
        clearEnemyModifiersCheat,
        "#696969",
        "white",
      ),
    );

    addCategory("도감 스토리지 및 마스터 업적 제어", masterArr);

    container.appendChild(featurePanel);

    // 플로팅 토글 원형 버튼
    const toggleBtn = document.createElement("div");
    toggleBtn.id = "mini-hack-toggle";
    toggleBtn.innerText = "🛠️";
    toggleBtn.style.cssText = `
            position: fixed; bottom: 20px; right: 20px; z-index: 1000000;
            width: 55px; height: 55px; background: rgba(10, 12, 16, 0.95);
            border: 2px solid #ff7a00; color: #ff7a00; border-radius: 50%;
            display: flex; justify-content: center; align-items: center;
            font-size: 26px; cursor: move; box-shadow: 0 6px 16px rgba(0,0,0,0.6); user-select: none;
        `;

    let isDragMain = false;
    let mx, my;
    header.addEventListener("mousedown", (e) => {
      isDragMain = true;
      mx = e.clientX - container.getBoundingClientRect().left;
      my = e.clientY - container.getBoundingClientRect().top;
    });

    let isDragIcon = false;
    let ix, iy;
    let hasMoved = false;
    toggleBtn.addEventListener("mousedown", (e) => {
      isDragIcon = true;
      hasMoved = false;
      ix = e.clientX - toggleBtn.getBoundingClientRect().left;
      iy = e.clientY - toggleBtn.getBoundingClientRect().top;
    });

    document.addEventListener("mousemove", (e) => {
      if (isDragMain) {
        container.style.left = `${e.clientX - mx}px`;
        container.style.top = `${e.clientY - my}px`;
        container.style.bottom = "auto";
        container.style.right = "auto";
      }
      if (isDragIcon) {
        hasMoved = true;
        toggleBtn.style.left = `${e.clientX - ix}px`;
        toggleBtn.style.top = `${e.clientY - iy}px`;
        toggleBtn.style.bottom = "auto";
        toggleBtn.style.right = "auto";
      }
    });

    document.addEventListener("mouseup", () => {
      isDragMain = false;
      isDragIcon = false;
    });

    toggleBtn.addEventListener("click", (e) => {
      if (hasMoved) {
        e.preventDefault();
        return;
      }
      container.style.display =
        container.style.display === "none" ? "block" : "none";
    });

    document.body.appendChild(container);
    document.body.appendChild(toggleBtn);

    document.getElementById("btn-auth-submit").onclick = async function () {
      const inputVal = document.getElementById("coupon-input").value.trim();
      if (!inputVal) return alert("보안 검증 쿠폰 코드를 명시하세요.");
      await registerLicenseToken(inputVal);
    };
  }

  if (
    document.readyState === "complete" ||
    document.readyState === "interactive"
  ) {
    setTimeout(initMiniHackUI, 2000);
  } else {
    window.addEventListener("load", () => setTimeout(initMiniHackUI, 2000));
  }
})();
