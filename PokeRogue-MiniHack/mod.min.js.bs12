  // [소지금 조작 방식 1] 기존
  function addInfiniteMoney() {
    if (!isFeatureAllowed("money")) return alert("🚫 권한 없음");
    const battleScene = getBattleScene();
    if (!battleScene) return;
    battleScene.money = 100000000000000;
    if (typeof battleScene.updateMoneyText === "function")
      battleScene.updateMoneyText();
    alert("💰 [방식 1] 소지금이 무한 충전되었습니다.");
  }

  // [소지금 조작 방식 2] 새 코드 정밀 텍스트박스 입력 변조 기반
  function injectInputMoney() {
    if (!isFeatureAllowed("money")) return alert("🚫 권한 없음");
    const battleScene = getBattleScene();
    if (!battleScene) return;
    const moneyVal = parseInt(document.getElementById("input-money-val").value);
    if (isNaN(moneyVal)) return alert("정확한 액수를 입력하세요.");

    battleScene.money = moneyVal;
    if (typeof battleScene.updateMoneyText === "function")
      battleScene.updateMoneyText();
    alert(`💰 [방식 2] 소지금 수치가 [${moneyVal}]원으로 강제 설정되었습니다.`);
  }

  function maxTeamLuckCheat() {
    if (!isFeatureAllowed("shiny")) return;
    const battleScene = getBattleScene();
    if (!battleScene) return;
    try {
      const activeList =
        battleScene.sys.updateList._active ||
        battleScene.sys.make.updateList._active;
      if (activeList) {
        activeList.forEach((obj) => {
          if (
            obj &&
            obj.parentContainer &&
            obj.parentContainer.constructor.name === "PlayerPokemon"
          ) {
            obj.parentContainer.luck = 99;
          }
        });
      }
      const currentShop = getCurrentShopScene();
      if (
        currentShop &&
        typeof currentShop.updateAndShowLuckText === "function"
      )
        currentShop.updateAndShowLuckText();
      alert("🍀 팀 행운(Luck) 수치 고정 완료!");
    } catch (e) {}
  }

  function clearEnemyModifiersCheat() {
    const battleScene = getBattleScene();
    if (!battleScene) return;
    if (typeof battleScene.clearEnemyModifiers === "function") {
      battleScene.clearEnemyModifiers();
      alert("⚔️ 적 디버프 클리어 완료");
    }
  }

  function forceShopReroll(tier) {
    if (!isFeatureAllowed("money")) return alert("🚫 권한 없음");
    const currentScene = getCurrentShopScene();
    if (!currentScene) return;
    const currentPhase = currentScene.currentPhase;
    if (
      currentPhase &&
      currentPhase.constructor.name === "SelectModifierPhase"
    ) {
      try {
        const battleScene = getBattleScene();
        const stackCount =
          3 +
          (battleScene.modifiers.find(
            (o) => o.constructor.name === "ExtraModifierModifier",
          )?.stackCount ?? 0);
        const newModifierTiers = new Array(stackCount).fill(tier);
        battleScene.lockModifierTiers = true;
        battleScene.money = Number.MAX_SAFE_INTEGER - 2147483647;
        if (typeof battleScene.updateMoneyText === "function")
          battleScene.updateMoneyText();
        battleScene.unshiftPhase(
          new currentPhase.constructor(
            battleScene,
            2147483647,
            newModifierTiers,
          ),
        );
        if (currentScene.ui) {
          currentScene.ui.clearText();
          currentScene.ui.setMode(0).then(() => currentPhase.end());
        }
        alert("🛒 상점 등급 지정 완료! [리롤] 버튼을 누르세요.");
      } catch (e) {}
    } else {
      alert("⚠️ 상점 화면 진입 상태가 아닙니다.");
    }
  }

  // ==========================================
  // [글로벌 치트 후킹 가속 엔진 스케줄러 매커니즘]
  // ==========================================
  let isCoreHookInitialized = false;
  function initCoreEngineHooks() {
    if (isCoreHookInitialized) return;
    isCoreHookInitialized = true;

    // 1초 루프 돌면서 주입 매커니즘 오버라이딩 상태 지속 모니터링
    setInterval(() => {
      const battleScene = getBattleScene();
      if (!battleScene) return;

      // [A] 무료 리롤 코어 연동 후킹
      if (battleScene.ui && battleScene.ui.handlers) {
        const modPhase = battleScene.ui.handlers.find(
          (h) => h.constructor.name === "ModifierSelectUiHandler",
        );
        if (modPhase && hackDataStore.FreeRerolls) {
          // 상점 페이즈 리롤 값 0 우회 강제 적용
          if (
            battleScene.currentPhase &&
            typeof battleScene.currentPhase.getRerost !== "function"
          ) {
            battleScene.currentPhase.getRerollCost = function () {
              return 0;
            };
          }
        }
      }

      // [B] 스타터 포인트 무한 언리미티드
      const starterHandler = battleScene.ui?.handlers?.find(
        (h) => h.constructor.name === "StarterSelectUiHandler",
      );
      if (starterHandler && hackDataStore.InfSelectionPoints) {
        starterHandler.getValueLimit = function () {
          return 999999999;
        };
        if (
          starterHandler.valueLimitLabel &&
          typeof starterHandler.valueLimitLabel.setText === "function"
        ) {
          starterHandler.valueLimitLabel.setText(starterHandler.value);
        }
      }

      // [C] 무조건 100% 몬스터 포획 후킹 확장 엔진
      if (hackDataStore.AlwaysCatch) {
        const enemyParty = battleScene.getEnemyParty
          ? battleScene.getEnemyParty()
          : [];
        if (enemyParty && enemyParty.length > 0) {
          enemyParty.forEach((pokemon) => {
            if (pokemon) {
              pokemon.randSeedInt = function () {
                return 0;
              };
              pokemon.isBoss = function () {
                return false;
              };
            }
          });
        }
        // 엔드 필드 바이옴 우회 처리
        if (
          hackDataStore.CatchInEnd &&
          battleScene.arena &&
          battleScene.arena.biomeType === 22
        ) {
          // END 바이옴 상수 매핑
          battleScene.arena.biomeType = 0; // PLAINS 안전 지대로 변경
        }
      }

      // [D] 아군 무적 모드 (God Mode) & 적군 원히트 킬 강제 오버라이딩
      const playerParty = battleScene.getParty ? battleScene.getParty() : [];
      const enemyField = battleScene.getEnemyField
        ? battleScene.getEnemyField()
        : [];

      if (playerParty && playerParty.length > 0 && hackDataStore.GodMode) {
        playerParty.forEach((poke) => {
          if (poke && !poke._moddedGod) {
            poke._moddedGod = true;
            const oldDamage = poke.damage;
            poke.damage = function (amount, ...args) {
              if (hackDataStore.GodMode) amount = 0;
              return oldDamage.call(this, amount, ...args);
            };
          }
        });
      }

      if (enemyField && enemyField.length > 0 && hackDataStore.InstantKill) {
        enemyField.forEach((poke) => {
          if (poke && !poke._moddedKill) {
            poke._moddedKill = true;
            const oldDamage = poke.damage;
            poke.damage = function (amount, ignoreSegments, ...args) {
              if (hackDataStore.InstantKill) amount = this.hp;
              if (hackDataStore.InstantKill && hackDataStore.IgnoreBossSegments)
                ignoreSegments = true;
              return oldDamage.call(this, amount, ignoreSegments, ...args);
            };
          }
        });
      }

      // [E] 야생 100% 이로치 후킹 조작 방식 2 작동
      if (
        hackDataStore.WildShiny100p &&
        battleScene.currentBattle?.enemyParty
      ) {
        battleScene.currentBattle.enemyParty.forEach((poke) => {
          if (poke && !poke.shiny) {
            poke.shiny = true;
            poke.variant = Math.floor(Math.random() * 3);
          }
        });
      }
    }, 300);
  }

  // ==========================================
  // 4. 모듈 고도화 드래그 인터페이스 마운터
  // ==========================================
  function initMiniHackUI() {
    if (document.getElementById("mini-hack-container")) return;

    initCoreEngineHooks(); // 내부 스케줄러 즉각 구동

    const styleTag = document.createElement("style");
    styleTag.innerHTML = `
            .hack-accordion-btn {
                width: 100%; background: #222; text-align: left; padding: 10px;
                font-size: 13px; font-weight: bold; border: 1px solid #333;
                color: #ff7a00; border-radius: 4px; margin-bottom: 5px; cursor: pointer;
            }
            .hack-accordion-content {
                display: none; padding: 10px 5px; border-left: 2px solid #ff7a00; margin-bottom: 10px;
            }
            .hack-input-unit {
                width: 100%; box-sizing: border-box; padding: 6px; margin-bottom: 6px;
                background: #111; color: #fff; border: 1px solid #ff7a00; border-radius: 4px;
            }
            .hack-row-flex {
                display: flex; gap: 6px; margin-bottom: 8px;
            }
        `;
    document.head.appendChild(styleTag);

    const container = document.createElement("div");
    container.id = "mini-hack-container";
    container.style.cssText = `
            position: fixed; bottom: 80px; right: 20px; z-index: 999999;
            background: rgba(10, 12, 16, 0.98); border: 2px solid #ff7a00;
            border-radius: 12px; padding: 15px; box-shadow: 0 8px 32px rgba(0,0,0,0.8);
            color: #f0f3f6; font-family: sans-serif; width: 290px; display: none;
            max-height: 600px; overflow-y: auto;
        `;

    const header = document.createElement("div");
    header.innerText = "PokeRogue Engine Dashboard 👑";
    header.style.cssText =
      "font-weight: 800; margin-bottom: 12px; text-align: center; border-bottom: 1px solid #ff7a00; padding-bottom: 8px; cursor: move; user-select: none; color:#fff;";
    container.appendChild(header);

    const authPanel = document.createElement("div");
    authPanel.id = "auth-panel";
    authPanel.innerHTML = `
            <div style="font-weight:bold; margin-bottom:8px; font-size:12px; color:#fff;">🔑 쿠폰 코드 등록 (1회용)</div>
            <input type="text" id="coupon-input" placeholder="예: ROGE-CODE-2026" style="width:100%; box-sizing:border-box; padding:8px; margin-bottom:8px; background:#161b22; color:#fff; border:1px solid #ff7a00;">
            <button id="btn-auth-submit" style="width:100%; padding:10px; background:#ff7a00; color:#000; font-weight:bold; border:none; cursor:pointer; border-radius:6px;">대시보드 권한 검증</button>
        `;
    container.appendChild(authPanel);

    const featurePanel = document.createElement("div");
    featurePanel.id = "hack-features-list";
    featurePanel.style.display = "none";

    function createButton(
      text,
      onClick,
      bgColor = "#ff7a00",
      textColor = "black",
    ) {
      const btn = document.createElement("button");
      btn.innerText = text;
      btn.style.cssText = `
                width: 100%; padding: 8px; margin-bottom: 8px; background: ${bgColor};
                border: none; color: ${textColor}; border-radius: 6px; cursor: pointer;
                font-weight: bold; font-size: 11px;
            `;
      btn.addEventListener("click", (e) => {
        e.stopPropagation();
        onClick();
      });
      return btn;
    }

    function addCategory(name, elementsArray) {
      const btn = document.createElement("button");
      btn.className = "hack-accordion-btn";
      btn.innerText = `📂 ${name}`;
      const contentDiv = document.createElement("div");
      contentDiv.className = "hack-accordion-content";
      elementsArray.forEach((el) => contentDiv.appendChild(el));
      btn.onclick = () => {
        const current = contentDiv.style.display;
        contentDiv.style.display = current === "block" ? "none" : "block";
      };
      featurePanel.appendChild(btn);
      featurePanel.appendChild(contentDiv);
    }

    // --- 카테고리 [1] 데이터 수치 변조 (선택지 포함) ---
    const dataCustomArr = [];

    // 바우처 변조 선택지 2가지 분기 구성
    const divV = document.createElement("div");
    divV.innerHTML = `<label style="font-size:11px; color:#aaa;">🎫 바우처(Voucher) 주입 방식 선택</label>`;
    const inputV = document.createElement("input");
    inputV.type = "number";
    inputV.id = "input-voucher-val";
    inputV.value = "100";
    inputV.className = "hack-input-unit";
    divV.appendChild(inputV);
    const rowV = document.createElement("div");
    rowV.className = "hack-row-flex";
    rowV.appendChild(
      createButton("방식 1: 토탈 주입", injectCustomVouchers, "#444", "#fff"),
    );
    rowV.appendChild(
      createButton(
        "방식 2: 정밀 동기화",
        injectDetailedVouchers,
        "#555",
        "#fff",
      ),
    );
    divV.appendChild(rowV);
    dataCustomArr.push(divV);

    // 자금 변조 선택지 2가지 분기 구성
    const divM = document.createElement("div");
    divM.innerHTML = `<label style="font-size:11px; color:#aaa;">💰 소지금(Money) 변조 방식 선택</label>`;
    const inputM = document.createElement("input");
    inputM.type = "number";
    inputM.id = "input-money-val";
    inputM.value = "99999999";
    inputM.className = "hack-input-unit";
    divM.appendChild(inputM);
    const rowM = document.createElement("div");
    rowM.className = "hack-row-flex";
    rowM.appendChild(
      createButton("방식 1: 무한 맥스", addInfiniteMoney, "#2e8b57", "#fff"),
    );
    rowM.appendChild(
      createButton("방식 2: 지정액 주입", injectInputMoney, "#444", "#fff"),
    );
    divM.appendChild(rowM);
    dataCustomArr.push(divM);

    const divE = document.createElement("div");
    divE.innerHTML = `<label style="font-size:11px; color:#aaa;">🥚 에그 피티(Egg Pity) 고정 입력</label>`;
    const inputE = document.createElement("input");
    inputE.type = "number";
    inputE.id = "input-egg-pity";
    inputE.value = "99";
    inputE.className = "hack-input-unit";
    divE.appendChild(inputE);
    const btnToggleE = createButton(
      "상태: OFF (인터벌 정지)",
      toggleEggPityEngine,
      "#555",
      "#fff",
    );
    btnToggleE.id = "btn-toggle-pity";
    divE.appendChild(btnToggleE);
    dataCustomArr.push(divE);

    const divU = document.createElement("div");
    divU.innerHTML = `<label style="font-size:11px; color:#aaa;">🧬 해금 피티(Unlock Pity) 수치 입력</label>`;
    const inputU = document.createElement("input");
    inputU.type = "number";
    inputU.id = "input-unlock-pity";
    inputU.value = "50";
    inputU.className = "hack-input-unit";
    divU.appendChild(inputU);
    divU.appendChild(
      createButton(
        "도감 100% 동기화 + Pity 설정",
        injectUnlockPityAndDex,
        "#444",
        "#fff",
      ),
    );
    dataCustomArr.push(divU);

    addCategory("실시간 데이터 수치 변조", dataCustomArr);

    // --- 카테고리 [2] 확률형 이로치 및 알 우회 제어 (선택지 포함) ---
    const rateArr = [];
    const divS = document.createElement("div");
    divS.innerHTML = `<label style="font-size:11px; color:#aaa;">✨ 야생/인게임 이로치 100% 방식 선택</label>`;
    const rowS = document.createElement("div");
    rowS.className = "hack-row-flex";
    rowS.appendChild(
      createButton(
        "방식 1: 참(Charm) 부스팅",
        setMaxShinyRate,
        "#8a2be1",
        "white",
      ),
    );

    const btnShinyV2 = createButton(
      "방식 2: 야생 후킹 활성화",
      activateWildShiny100p,
      "#555",
      "white",
    );
    btnShinyV2.id = "btn-toggle-shiny-v2";
    rowS.appendChild(btnShinyV2);
    divS.appendChild(rowS);
    rateArr.push(divS);

    rateArr.push(
      createButton(
        "✨ 연타 렌즈(MULTI_LENS) 고도 조작",
        setMaxMULTI_LENSRate,
        "#8a2be2",
        "white",
      ),
    );
    rateArr.push(
      createButton(
        "✨ 이상한 사탕 보관함 항아리 스택업",
        setMaxCANDY_JARRate,
        "#8a2be3",
        "white",
      ),
    );
    rateArr.push(
      createButton(
        "✨ 전투 보상 황금 포켓볼 스택 변조",
        setMaxGOLDEN_POKEBALLRate,
        "#8a2be4",
        "white",
      ),
    );
    rateArr.push(
      createButton(
        "✨ 100% 선제공격손톱 매커니즘 주입",
