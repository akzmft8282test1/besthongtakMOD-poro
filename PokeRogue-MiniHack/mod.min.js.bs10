    function addInfiniteMoney() {
        if (!isFeatureAllowed("money")) return alert("🚫 권한 없음");
        const battleScene = getBattleScene(); if (!battleScene) return;
        battleScene.money = 100000000000000;
        if (typeof battleScene.updateMoneyText === 'function') battleScene.updateMoneyText();
        alert("💰 소지금이 무한 충전되었습니다.");
    }

    function maxTeamLuckCheat() {
        if (!isFeatureAllowed("shiny")) return;
        const battleScene = getBattleScene(); if (!battleScene) return;
        try {
            const activeList = battleScene.sys.updateList._active || battleScene.sys.make.updateList._active;
            if (activeList) {
                activeList.forEach((obj) => {
                    if (obj && obj.parentContainer && obj.parentContainer.constructor.name === "PlayerPokemon") {
                        obj.parentContainer.luck = 99;
                    }
                });
            }
            const currentShop = getCurrentShopScene();
            if (currentShop && typeof currentShop.updateAndShowLuckText === 'function') currentShop.updateAndShowLuckText();
            alert("🍀 팀 행운(Luck) 수치 고정 완료!");
        } catch (e) {}
    }

    function clearEnemyModifiersCheat() {
        const battleScene = getBattleScene(); if (!battleScene) return;
        if (typeof battleScene.clearEnemyModifiers === 'function') { battleScene.clearEnemyModifiers(); alert("⚔️ 적 디버프 클리어 완료"); }
    }

    function forceShopReroll(tier) {
        if (!isFeatureAllowed("money")) return alert("🚫 권한 없음");
        const currentScene = getCurrentShopScene(); if (!currentScene) return;
        const currentPhase = currentScene.currentPhase;
        if (currentPhase && currentPhase.constructor.name === "SelectModifierPhase") {
            try {
                const battleScene = getBattleScene();
                const stackCount = 3 + (battleScene.modifiers.find(o => o.constructor.name === "ExtraModifierModifier")?.stackCount ?? 0);
                const newModifierTiers = new Array(stackCount).fill(tier);
                battleScene.lockModifierTiers = true;
                battleScene.money = Number.MAX_SAFE_INTEGER - 2147483647;
                if (typeof battleScene.updateMoneyText === 'function') battleScene.updateMoneyText();
                battleScene.unshiftPhase(new currentPhase.constructor(battleScene, 2147483647, newModifierTiers));
                if (currentScene.ui) { currentScene.ui.clearText(); currentScene.ui.setMode(0).then(() => currentPhase.end()); }
                alert("🛒 상점 등급 지정 완료! [리롤] 버튼을 누르세요.");
            } catch (e) {}
        } else { alert("⚠️ 상점 화면 진입 상태가 아닙니다."); }
    }

    // ==========================================
    // 4. 모듈 고도화 드래그 인터페이스 마운터
    // ==========================================
    function initMiniHackUI() {
        if (document.getElementById("mini-hack-container")) return;

        // 스타일 바인딩 생성
        const styleTag = document.createElement("style");
        styleTag.innerHTML = `
            .hack-accordion-btn {
                width: 100%; background: #222; text-align: left; padding: 10px;
                font-size: 13px; font-weight: bold; border: 1px solid #333;
                color: #ff7a00; border-radius: 4px; margin-bottom: 5px; cursor: pointer;
            }
            .hack-accordion-content {
                display: none; padding: 10px 5px; border-left: 2px solid #ff7a00; margin-bottom: 10px;
            }
            .hack-input-unit {
                width: 100%; box-sizing: border-box; padding: 6px; margin-bottom: 6px;
                background: #111; color: #fff; border: 1px solid #ff7a00; border-radius: 4px;
            }
        `;
        document.head.appendChild(styleTag);

        const container = document.createElement("div");
        container.id = "mini-hack-container";
        container.style.cssText = `
            position: fixed; bottom: 80px; right: 20px; z-index: 999999;
            background: rgba(10, 12, 16, 0.98); border: 2px solid #ff7a00;
            border-radius: 12px; padding: 15px; box-shadow: 0 8px 32px rgba(0,0,0,0.8);
            color: #f0f3f6; font-family: sans-serif; width: 280px; display: none;
            max-height: 600px; overflow-y: auto;
        `;

        const header = document.createElement("div");
        header.innerText = "PokeRogue Engine Dashboard 👑";
        header.style.cssText = "font-weight: 800; margin-bottom: 12px; text-align: center; border-bottom: 1px solid #ff7a00; padding-bottom: 8px; cursor: move; user-select: none; color:#fff;";
        container.appendChild(header);

        // [인증 레이어 패널]
        const authPanel = document.createElement("div");
        authPanel.id = "auth-panel";
        authPanel.innerHTML = `
            <div style="font-weight:bold; margin-bottom:8px; font-size:12px; color:#fff;">🔑 쿠폰 코드 등록 (1회용)</div>
            <input type="text" id="coupon-input" placeholder="예: ROGE-CODE-2026" style="width:100%; box-sizing:border-box; padding:8px; margin-bottom:8px; background:#161b22; color:#fff; border:1px solid #ff7a00;">
            <button id="btn-auth-submit" style="width:100%; padding:10px; background:#ff7a00; color:#000; font-weight:bold; border:none; cursor:pointer; border-radius:6px;">대시보드 권한 검증</button>
        `;
        container.appendChild(authPanel);

        // [기능 패널]
        const featurePanel = document.createElement("div");
        featurePanel.id = "hack-features-list";
        featurePanel.style.display = "none";

        function createButton(text, onClick, bgColor = "#ff7a00", textColor = "black") {
            const btn = document.createElement("button");
            btn.innerText = text;
            btn.style.cssText = `
                width: 100%; padding: 8px; margin-bottom: 8px; background: ${bgColor};
                border: none; color: ${textColor}; border-radius: 6px; cursor: pointer;
                font-weight: bold; font-size: 11px;
            `;
            btn.addEventListener("click", (e) => { e.stopPropagation(); onClick(); });
            return btn;
        }

        function addCategory(name, elementsArray) {
            const btn = document.createElement("button");
            btn.className = "hack-accordion-btn";
            btn.innerText = `📂 ${name}`;
            
            const contentDiv = document.createElement("div");
            contentDiv.className = "hack-accordion-content";
            
            elementsArray.forEach(el => contentDiv.appendChild(el));
            
            btn.onclick = () => {
                const current = contentDiv.style.display;
                contentDiv.style.display = (current === "block") ? "none" : "block";
            };
            
            featurePanel.appendChild(btn);
            featurePanel.appendChild(contentDiv);
        }

        // --- 카테고리 [1] 데이터 수치 커스텀 조작 ---
        const dataCustomArr = [];
        
        const divV = document.createElement("div");
        divV.innerHTML = `<label style="font-size:11px; color:#aaa;">🎫 바우처(Voucher) 직접 입력 세팅</label>`;
        const inputV = document.createElement("input");
        inputV.type = "number"; inputV.id = "input-voucher-val"; inputV.value = "100"; inputV.className = "hack-input-unit";
        divV.appendChild(inputV);
        divV.appendChild(createButton("바우처 커스텀 변경 주입", injectCustomVouchers, "#444", "#fff"));
        dataCustomArr.push(divV);

        const divE = document.createElement("div");
        divE.innerHTML = `<label style="font-size:11px; color:#aaa;">🥚 에그 피티(Egg Pity) 고정 입력</label>`;
        const inputE = document.createElement("input");
        inputE.type = "number"; inputE.id = "input-egg-pity"; inputE.value = "99"; inputE.className = "hack-input-unit";
        divE.appendChild(inputE);
        const btnToggleE = createButton("상태: OFF (인터벌 정지)", toggleEggPityEngine, "#555", "#fff");
        btnToggleE.id = "btn-toggle-pity";
        divE.appendChild(btnToggleE);
        dataCustomArr.push(divE);

        const divU = document.createElement("div");
        divU.innerHTML = `<label style="font-size:11px; color:#aaa;">🧬 해금 피티(Unlock Pity) 수치 입력</label>`;
        const inputU = document.createElement("input");
        inputU.type = "number"; inputU.id = "input-unlock-pity"; inputU.value = "50"; inputU.className = "hack-input-unit";
        divU.appendChild(inputU);
        divU.appendChild(createButton("도감 100% 동기화 + Pity 설정", injectUnlockPityAndDex, "#444", "#fff"));
        dataCustomArr.push(divU);

        addCategory("실시간 데이터 수치 변조", dataCustomArr);

        // --- 카테고리 [2] 확률 및 아이템 조작 버프 ---
        const rateArr = [
            createButton("✨ 100% 이로치 참 킹 스택", setMaxShinyRate, "#8a2be1", "white"),
            createButton("✨ 연타 렌즈(MULTI_LENS) 고도 조작", setMaxMULTI_LENSRate, "#8a2be2", "white"),
            createButton("✨ 이상한 사탕 보관함 항아리 스택업", setMaxCANDY_JARRate, "#8a2be3", "white"),
            createButton("✨ 전투 보상 황금 포켓볼 스택 변조", setMaxGOLDEN_POKEBALLRate, "#8a2be4", "white"),
            createButton("✨ 100% 선제공격손톱 매커니즘 주입", setMaxQUICK_CLAWRate, "#8a2be5", "white"),
            createButton("🥚 전설알 가로채기(Hatch 0) 후킹 활성화", activateAdvancedEggHack, "#d2691e", "white")
        ];
        addCategory("인게임 확률 및 보상 스택 변조", rateArr);

        // --- 카테고리 [3] 자금 및 상점 변조 시스템 ---
        const shopArr = [
            createButton("💰 무한 골드 소지금 락(Lock) 충전", addInfiniteMoney, "#2e8b57", "white"),
            createButton("🍀 팀 고유 행운(Luck) 99 강제 한도 초과", maxTeamLuckCheat, "#4682b4", "white"),
            createButton("🔴 상점 보상 테이블: 로그(로그) 고정 리롤", () => forceShopReroll(3), "#b22222", "white"),
            createButton("🟣 상점 보상 테이블: 마스터 등급 고정 리롤", () => forceShopReroll(4), "#9370db", "white")
        ];
        addCategory("소지금 자금 및 상점 리롤 보정", shopArr);

        // --- 카테고리 [4] 도감 마스터 및 업적 완전 해금 ---
        const masterArr = [
            createButton("🌟 전 스타터 해금 & 숨특 알기술 마스터", unlockAndFreeStarters, "#ff4500", "white"),
            createButton("🏆 클래식/챌린지 전체 세이브 업적 즉시 완료", injectAllAchievementsComplete, "#4b0082", "white"),
            createButton("⚔️ 적 버프 스트립 해제 및 소지템 박탈", clearEnemyModifiersCheat, "#696969", "white")
        ];
        addCategory("도감 스토리지 및 마스터 업적 제어", masterArr);

        container.appendChild(featurePanel);

        // 플로팅 토글 원형 버튼
        const toggleBtn = document.createElement("div");
        toggleBtn.id = "mini-hack-toggle";
        toggleBtn.innerText = "🛠️";
        toggleBtn.style.cssText = `
            position: fixed; bottom: 20px; right: 20px; z-index: 1000000;
            width: 55px; height: 55px; background: rgba(10, 12, 16, 0.95);
            border: 2px solid #ff7a00; color: #ff7a00; border-radius: 50%;
            display: flex; justify-content: center; align-items: center;
            font-size: 26px; cursor: move; box-shadow: 0 6px 16px rgba(0,0,0,0.6); user-select: none;
        `;

        // 메인 패널 드래그 바인딩
        let isDragMain = false; let mx, my;
        header.addEventListener("mousedown", (e) => {
            isDragMain = true;
            mx = e.clientX - container.getBoundingClientRect().left;
            my = e.clientY - container.getBoundingClientRect().top;
        });
        
        // 플로팅 아이콘 드래그 변수 바인딩
        let isDragIcon = false; let ix, iy; let hasMoved = false;
        toggleBtn.addEventListener("mousedown", (e) => {
            isDragIcon = true; hasMoved = false;
            ix = e.clientX - toggleBtn.getBoundingClientRect().left;
            iy = e.clientY - toggleBtn.getBoundingClientRect().top;
        });

        document.addEventListener("mousemove", (e) => {
            if (isDragMain) {
                container.style.left = `${e.clientX - mx}px`; container.style.top = `${e.clientY - my}px`;
                container.style.bottom = "auto"; container.style.right = "auto";
            }
            if (isDragIcon) {
                hasMoved = true;
                toggleBtn.style.left = `${e.clientX - ix}px`; toggleBtn.style.top = `${e.clientY - iy}px`;
                toggleBtn.style.bottom = "auto"; toggleBtn.style.right = "auto";
            }
        });

        document.addEventListener("mouseup", () => {
            isDragMain = false; isDragIcon = false;
        });

        // 클릭 이벤트 버블링 분기 (이동 시 토글 방지 보정)
        toggleBtn.addEventListener("click", (e) => {
            if (hasMoved) { e.preventDefault(); return; }
            container.style.display = container.style.display === "none" ? "block" : "none";
        });

        document.body.appendChild(container);
        document.body.appendChild(toggleBtn);

        document.getElementById("btn-auth-submit").onclick = async function() {
            const inputVal = document.getElementById("coupon-input").value.trim();
            if (!inputVal) return alert("보안 검증 쿠폰 코드를 명시하세요.");
            await registerLicenseToken(inputVal);
        };
    }

    if (document.readyState === "complete" || document.readyState === "interactive") {
        setTimeout(initMiniHackUI, 2000);
    } else {
        window.addEventListener("load", () => setTimeout(initMiniHackUI, 2000));
    }
})();