            try {
                const mod = new window.PokeRoster ? null : new window.PokeRogue.modifier.ShinyRateBoosterModifier(window.PokeRogue.modifier.modifierTypes.GOLDEN_POKEBALL());
                await battleScene.updateModifiers(true, true); await battleScene.addModifier(mod, false, false, false, true);
                index = modifiers.findIndex(({ type: { localeKey } }) => localeKey === "modifierType:ModifierType.GOLDEN_POKEBALL");
            } catch(e) {}
        }
        if (index !== -1) { modifiers[index].stackCount = 50; await battleScene.updateModifiers(true, true); alert("✨ 황금 몬스터볼 조작 성공!"); }
    }

    async function setMaxQUICK_CLAWRate() {
