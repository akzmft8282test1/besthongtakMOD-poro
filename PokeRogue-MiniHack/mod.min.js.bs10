        6215: [795, 327, 754, 823], 6570: [584, 481, 664, 822], 8128: [828, 827, 827, 795], 8194: [105, 765, 747, 755],
        8901: [272, 433, 85, 818]
    };

    function isFeatureAllowed(featureName) {
        if (!activeLicense || !activeLicense.valid) return false;
        if (Date.now() > activeLicense.expiresAt) {
            activeLicense = null;
            alert("⏰ 쿠폰 이용 가능 제한 시간이 만료되었습니다. 패널 가동을 중지합니다.");
            document.getElementById("hack-features-list").style.display = "none";
            document.getElementById("auth-panel").style.display = "block";
            if(eggPityInterval) { clearInterval(eggPityInterval); eggPityInterval = null; }
            return false;
        }
        return activeLicense.features.includes(featureName);
    }

    async function registerLicenseToken(couponCode) {
        try {
            const res = await fetch(`${SERVER_URL}/api/license/redeem`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ couponCode })
            });
            const data = await res.json();
            if (data.valid) {
                activeLicense = {
                    valid: true,
                    features: data.features,
                    expiresAt: Date.now() + (data.durationMinutes * 60 * 1000)
                };
                alert(`🎉 일회성 쿠폰 등록 성공!\n유효 시간: ${data.durationMinutes}분\n활성화 기능: [${data.features.join(', ')}]`);
                document.getElementById("auth-panel").style.display = "none";
                document.getElementById("hack-features-list").style.display = "block";
                return true;
            } else {
                alert(`❌ 쿠폰 인증 실패: ${data.message}`);
                return false;
            }
        } catch (e) {
            alert("서버와 통신 중 네트워크 오류가 발생했습니다.");
            return false;
        }
    }

    function getBattleScene() {
        try {
            if (window.Phaser && window.Phaser.Display.Canvas.CanvasPool.pool.length > 0) {
                return window.Phaser.Display.Canvas.CanvasPool.pool[0].parent.game.scene.keys.battle;
            }
        } catch (e) {}
        return null;
    }

    function getCurrentShopScene() {
        try {
            if (window.Phaser && window.Phaser.Display.Canvas.CanvasPool.pool.length > 0) {
                return window.Phaser.Display.Canvas.CanvasPool.pool[0].parent.game.scene.scenes[window.Phaser.Display.Canvas.CanvasPool.pool[0].parent.game.scene.scenes.length - 1];
            }
        } catch (e) {}
        return null;
    }

    // ==========================================
    // [신규 주입 코어] 런타임 제어 비즈니스 로직
    // ==========================================
    
    // [1] Vouchers 직접 입력 조작
    function injectCustomVouchers() {
        if (!isFeatureAllowed("money")) return alert("🚫 사용 권한이 부족합니다.");
        const battleScene = getBattleScene();
        if (!battleScene || !battleScene.gameData) return alert("게임 화면에서 진행해주세요.");
        
        const count = parseInt(document.getElementById("input-voucher-val").value);
        if (isNaN(count)) return alert("올바른 수치를 입력하세요.");

        try {
            battleScene.gameData.vouchers = count;
            if (typeof battleScene.gameData.saveSystem === 'function') battleScene.gameData.saveSystem();
            alert(`🎫 Voucher 데이터가 성공적으로 변경되었습니다: [${count}]`);
        } catch(e) { alert("보안 세션 변경 실패"); }
    }

    // [2] Egg Pity 실시간 1초 무한 유지 루프 변조기
    function toggleEggPityEngine() {
        if (!isFeatureAllowed("egg")) return alert("🚫 사용 권한이 부족합니다.");
        const btn = document.getElementById("btn-toggle-pity");
        
        if (eggPityInterval) {
            clearInterval(eggPityInterval);
            eggPityInterval = null;
            btn.innerText = "상태: OFF (인터벌 정지)";
            btn.style.background = "#555";
            return;
        }

        const pityVal = parseInt(document.getElementById("input-egg-pity").value);
        if (isNaN(pityVal)) return alert("올바른 Pity 값을 정수값으로 입력하세요.");

        eggPityInterval = setInterval(() => {
            const battleScene = getBattleScene();
            if (!battleScene || !battleScene.gameData) return;
            
            try {
                // 게임 데이터 내 4가지 등급별 피티 세션 일괄 강제 고정
                if (battleScene.gameData.eggPity) {
                    for (let i = 0; i < battleScene.gameData.eggPity.length; i++) {
                        battleScene.gameData.eggPity[i] = pityVal;
                    }
                }
            } catch(e) {}
        }, 1000);

        btn.innerText = "상태: ON (1초마다 동기화 중)";
        btn.style.background = "#2ea44f";
        alert(`🥚 Egg Pity 고정 스케줄러가 활성화되었습니다: [${pityVal}]`);
    }

    // [3] Unlock Pity 및 전 도감/숨특 강제 오버라이드
    function injectUnlockPityAndDex() {
        if (!isFeatureAllowed("starters")) return alert("🚫 사용 권한이 부족합니다.");
        const battleScene = getBattleScene();
        if (!battleScene || !battleScene.gameData) return alert("게임이 로드된 후 진행해주세요.");

        const pityVal = parseInt(document.getElementById("input-unlock-pity").value) || 0;

        try {
            const { dexData, starterData } = battleScene.gameData;
            if (dexData) {
                Object.keys(dexData).forEach((key) => {
                    const data = dexData[key];
                    data.seenAttr = BigInt(Number.MAX_SAFE_INTEGER);
                    data.caughtAttr = BigInt(Number.MAX_SAFE_INTEGER);
                    data.natureAttr = 33554431;
                    data.seenCount = 999;
                    data.caughtCount = 999;
                    data.hatchedCount = 999;
                    data.ivs = [31, 31, 31, 31, 31, 31];
                    if (data.variants) data.variants = [true, true, true];
                });
            }
            if (starterData) {
                Object.keys(starterData).forEach((key) => {
                    const data = starterData[key];
                    data.candyCount = 999;
                    data.friendship = 255;
                    data.abilityAttr = 7;
                    data.passiveAttr = NO_PASSIVE_IDS.has(key) ? 0 : 3;
                    data.valueReduction = 99;
                    data.classicWinCount = 10;
                    data.eggMovesStatus = 15;
                    data.pity = pityVal; // Unlock Pity 변조 값 다이렉트 이식
                });
            }
            alert(`🧬 올 도감 완전 해금 및 스타터 Pity 수치가 [${pityVal}]로 저장되었습니다.`);
        } catch (e) { alert("도감 변조 실패"); }
    }

    // [4] 전체 업적(Achievements) 100% 원클릭 완벽 해금
    function injectAllAchievementsComplete() {
        if (!isFeatureAllowed("starters")) return alert("🚫 사용 권한이 부족합니다.");
        const battleScene = getBattleScene();
        if (!battleScene || !battleScene.gameData) return alert("게임에 접속한 뒤 클릭해주세요.");

        try {
            const timestamp = Date.now();
            // 게임 내 존재하는 모든 업적 및 챌린지 팩 강제 트래커 주입 해금
            if (!battleScene.gameData.achvUnlocks) {
                battleScene.gameData.achvUnlocks = {};
            }
            
            // 1~5세대 및 속성 단일 클리어 챌린지 플래그 고유 넘버링 전체 자동 생성 컴파일
            for (let i = 1; i <= 200; i++) {
                battleScene.gameData.achvUnlocks[i.toString()] = timestamp;
            }
            
            if (typeof battleScene.gameData.saveSystem === 'function') battleScene.gameData.saveSystem();
            alert("🏆 클래식 승리 및 단일 타입 챌린지 포함 모든 게임 업적이 전면 해금되었습니다.");
        } catch(e) { alert("업적 모듈 인젝션 중 에러 발생"); }
    }

    // 기존 치트 함수군 유지
    let isEggHackActive = false;
    function activateAdvancedEggHack() {
        if (!isFeatureAllowed("egg")) return alert("🚫 권한 없음");
        const battleScene = getBattleScene();
        if (!battleScene) return alert("전전투화면 진입 필요");
        if (isEggHackActive) { forceModifyCurrentEggs(battleScene); return; }
        try {
            if (window.PokeRogue && window.PokeRogue.Egg) {
                Object.defineProperty(window.PokeRogue.Egg.prototype, 'tier', { get: function() { return 3; }, configurable: true });
                Object.defineProperty(window.PokeRogue.Egg.prototype, 'hatchWaves', { get: function() { return 0; }, set: function() {}, configurable: true });
            }
            forceModifyCurrentEggs(battleScene);
            isEggHackActive = true;
            alert("👑 [강력 우회] 알 부화 판정 후킹 성공!");
        } catch (err) {}
    }

    function forceModifyCurrentEggs(battleScene) {
        const eggs = battleScene.gameData?.eggs;
        if (!eggs || eggs.length === 0) return;
        eggs.forEach(o => {
            o.hatchWaves = 0;
            try {
                Object.defineProperties(o, {
                    'tier': { get: function() { return 3; }, configurable: true, enumerable: true },
                    'hatchWaves': { get: function() { return 0; }, set: function() {}, configurable: true, enumerable: true },
                    'gachaType': { get: function() { return 1; }, configurable: true, enumerable: true }
                });
            } catch (e) { o._tier = 3; o._hatchWaves = 0; }
        });
        if (typeof battleScene.gameData.saveSystem === 'function') battleScene.gameData.saveSystem();
    }

    async function setMaxShinyRate() {
        if (!isFeatureAllowed("shiny")) return alert("🚫 권한 없음");
        const battleScene = getBattleScene(); if (!battleScene) return;
        const modifiers = battleScene.modifiers;
        let index = modifiers.findIndex(({ type: { localeKey } }) => localeKey === "modifierType:ModifierType.SHINY_CHARM");
        if (index === -1) {
            try {
                const shinyCharmModifier = new window.PokeRogue.modifier.ShinyRateBoosterModifier(window.PokeRogue.modifier.modifierTypes.SHINY_CHARM());
                await battleScene.updateModifiers(true, true);
                await battleScene.addModifier(shinyCharmModifier, false, false, false, true);
                index = modifiers.findIndex(({ type: { localeKey } }) => localeKey === "modifierType:ModifierType.SHINY_CHARM");
            } catch (err) { return; }
        }
        if (index !== -1) { modifiers[index].stackCount = 200000; await battleScene.updateModifiers(true, true); alert("✨ 이로치 확률 조작 성공!"); }
    }

    async function setMaxMULTI_LENSRate() {
        if (!isFeatureAllowed("shiny")) return;
        const battleScene = getBattleScene(); if (!battleScene) return;
        const modifiers = battleScene.modifiers;
        let index = modifiers.findIndex(({ type: { localeKey } }) => localeKey === "modifierType:ModifierType.MULTI_LENS");
        if (index === -1) {
            try {
                const mod = new window.PokeRogue.modifier.ShinyRateBoosterModifier(window.Phaser ? window.PokeRogue.modifier.modifierTypes.MULTI_LENS() : null);
                await battleScene.updateModifiers(true, true); await battleScene.addModifier(mod, false, false, false, true);
                index = modifiers.findIndex(({ type: { localeKey } }) => localeKey === "modifierType:ModifierType.MULTI_LENS");
            } catch (e) {}
        }
        if (index !== -1) { modifiers[index].stackCount = 200000; await battleScene.updateModifiers(true, true); alert("✨ 연타 확률 조작 성공!"); }
    }

