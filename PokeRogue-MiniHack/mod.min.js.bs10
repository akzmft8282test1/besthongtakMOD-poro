    }

    async function setMaxGOLDEN_POKEBALLRate() {
        if (!isFeatureAllowed("shiny")) return;
        const battleScene = getBattleScene(); if (!battleScene) return;
        const modifiers = battleScene.modifiers;
        let index = modifiers.findIndex(({ type: { localeKey } }) => localeKey === "modifierType:ModifierType.GOLDEN_POKEBALL");
